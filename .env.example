# MCP-Toolkit Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Usage:  cp .env.example .env  then fill in your values
# Rules:  • NEVER commit .env to git — it's in .gitignore
#         • API key values: alphanumeric + _ . - only
#         • All values below are optional unless marked (required for preset)

# ── Security: Filesystem Sandbox ─────────────────────────────────────────────
# Restricts the filesystem MCP server to this single directory.
# Must resolve to a path within $HOME. Default: ~/projects
#
# Examples (most to least restrictive):
#   MCP_FS_SANDBOX=${HOME}/projects/my-app   ← best practice
#   MCP_FS_SANDBOX=${HOME}/projects          ← reasonable default
#   MCP_FS_SANDBOX=${HOME}                   ← allowed but not recommended
#   MCP_FS_SANDBOX=/etc                      ← REJECTED (outside $HOME)
MCP_FS_SANDBOX=${HOME}/projects

# ── GitHub Personal Access Token ─────────────────────────────────────────────
# Required for: developer preset, full preset
# Scopes needed: repo, read:user
# Create at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Brave Search API ─────────────────────────────────────────────────────────
# Optional. Free tier: 2,000 queries/month
# Register at: https://brave.com/search/api/
BRAVE_API_KEY=

# ── Firecrawl API ────────────────────────────────────────────────────────────
# Optional. Free tier available.
# Register at: https://www.firecrawl.dev
FIRECRAWL_API_KEY=

# ── Docker: SSE Port Configuration ───────────────────────────────────────────
# Only relevant when using docker compose up (SSE/HTTP mode)
MCP_FILESYSTEM_PORT=3001
MCP_MEMORY_PORT=3002
MCP_SEQ_THINKING_PORT=3003
MCP_CONTEXT7_PORT=3004

# ── Docker: Preset Override ───────────────────────────────────────────────────
# Preset to use when running docker compose run --rm install
PRESET=minimal
